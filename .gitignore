# =============================================================================
#  .gitignore — StudentsFacialAttendanceMarker
#  Excludes everything created by setup.bat / setup.sh
# =============================================================================

# ---------------------------------------------------------------------------
#  Windows — generated by setup.bat
# ---------------------------------------------------------------------------

# Embedded Python 3.10.5 (downloaded portable zip)
windows/python/

# Virtual environment
windows/venv/

# InsightFace models (~300MB buffalo_l pack)
windows/models/

# Temporary files created during setup
windows/py3105.zip
windows/get-pip.py
windows/python-3.10.5-embed-amd64.zip

# SQLite database (created on first server run)
windows/backend/attendance.db
windows/backend/*.db

# ---------------------------------------------------------------------------
#  macOS — generated by setup.sh
# ---------------------------------------------------------------------------

# Local pyenv installation + compiled Python 3.10.5
macos/.pyenv/

# Virtual environment
macos/venv/

# InsightFace models (~300MB buffalo_l pack)
macos/models/

# SQLite database (created on first server run)
macos/backend/attendance.db
macos/backend/*.db

# ---------------------------------------------------------------------------
#  Python — both platforms
# ---------------------------------------------------------------------------

# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/

# ---------------------------------------------------------------------------
#  Logs and runtime output
# ---------------------------------------------------------------------------
*.log
logs/
*.pid

# ---------------------------------------------------------------------------
#  OS-generated files
# ---------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
#  IDE / editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------------------------------------------------------------------------
#  Secrets / environment files
# ---------------------------------------------------------------------------
.env
.env.local
*.secret
secrets.json
